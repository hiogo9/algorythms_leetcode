{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Generate Test File",
            "type": "shell",
            "command": "python3 ${workspaceFolder}/scripts/gen_test.py",
            "options": {
                "cwd": "${fileDirname}"
            },
            "presentation": {
                "reveal": "silent",
                "close": true
            }
        },
        {
            "label": "New Solution",
            "type": "shell",
            "command": "python3 ${workspaceFolder}/scripts/new_solution.py",
            "options": {
                "cwd": "${fileDirname}"
            },
            "presentation": {
                "reveal": "silent",
                "close": true
            }
        },
        {
            "label": "Swap with solution.py",
            "type": "shell",
            "command": "python3 ${workspaceFolder}/scripts/swap_solution.py ${fileBasename}",
            "options": {
                "cwd": "${fileDirname}"
            },
            "presentation": {
                "reveal": "silent",
                "close": true
            }
        }
    ]
}
